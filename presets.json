{
  "node": {
    "path": "${RUNNER_TOOL_CACHE}/node",
    "key-prefix": "node-${major}-${os}-${arch}",
    "version-command": ["node", "--version"],
    "version-pattern": "(\\d+\\.\\d+\\.\\d+)"
  },
  "python": {
    "path": "${RUNNER_TOOL_CACHE}/Python",
    "key-prefix": "python-${major}-${os}-${arch}",
    "version-command": ["python3", "--version"],
    "version-pattern": "(\\d+\\.\\d+\\.\\d+)"
  },
  "go": {
    "path": "${RUNNER_TOOL_CACHE}/go",
    "key-prefix": "go-${major}-${os}-${arch}",
    "version-command": ["go", "version"],
    "version-pattern": "go(\\d+\\.\\d+\\.\\d+)"
  }
}
